{
  "name": "spotter",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "npm run test:unit && npm run test:components",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:components": "jest --passWithNoTests",
    "test:components:watch": "jest --watch",
    "test:e2e": "maestro test e2e/"
  },
  "dependencies": {
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-nitro-modules": "^0.35.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-vision-camera": "^5.0.6",
    "react-native-worklets": "^0.8.1",
    "react-native-worklets-core": "^1.6.3",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-preset-expo": "^55.0.18",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "private": true
}
